{
  "manifest_version": 3,
  "name": "ScrollSync",
  "version": "1.0",
  "description": "Automates page scrolling at user-defined intervals.",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["index.html", "icon.png", "guide.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
